<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lange="clr-namespace:Sentez.Common.Localization;assembly=LiveCore.Desktop"
    xmlns:sye="clr-namespace:Sentez.Common.Extension;assembly=LiveCore.Desktop"
    xmlns:UtilCore="clr-namespace:Sentez.Common.Utilities;assembly=LiveCore"
    xmlns:live="clr-namespace:LiveCore.Desktop.UI.Controls;assembly=LiveCore.Desktop"
    xmlns:BoExt="clr-namespace:CashFlowManagementModule.BoExtensions;assembly=CashFlowManagementModule"
    x:Name="BankAccountPosView"
    Tag="BankAccountPosViewW">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="{lange:TranslateExtension Üye İş Yeri Hesap Bilgileri}" Margin="0,0,0,5">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <live:LiveLabel Grid.Column="0" HorizontalAlignment="Right" HorizontalContentAlignment="Right" Padding="2" VerticalContentAlignment="Center" Width="140" Content="{lange:TranslateExtension Üye İşyeri No}"/>
                <live:LiveTextEdit Grid.Column="1" Margin="2,1,1,0" HorizontalAlignment="Left" Width="200" EditValue="{sye:SBinding Field=Erp_BankAccount.UD_PosMerchantNo}"/>

                <live:LiveLabel Grid.Column="2" HorizontalAlignment="Right" HorizontalContentAlignment="Right" Padding="2" VerticalContentAlignment="Center" Width="140" Content="{lange:TranslateExtension Ekstre Görünüm Profili}"/>
                <live:LiveComboBoxEdit Grid.Column="3" Margin="2,1,1,0" HorizontalAlignment="Left" Width="200" ItemsSource="{sye:SBinding Path=Lists[PosStatementViewProfileList]}" DisplayMember="Display" ValueMember="Value" EditValue="{sye:SBinding Field=Erp_BankAccount.UD_PosStatementViewProfile}"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="{lange:TranslateExtension Kesinti Oran Profili}">
            <live:LiveGridControl x:Name="gridPosDeductionProfile"
                                  ShowBorder="False"
                                  SelectionMode="Row"
                                  AllowNewRow="True"
                                  AllowDeleteRow="True"
                                  BusinessObject="{Binding ActiveBO}"
                                  TableName="Erp_BankAccountPosDeductionProfile"
                                  ForeignKey="FK_Erp_BankAccountPosDeductionProfile_Erp_BankAccount"
                                  Lookups="{sye:SBinding Lists}">
                <live:LiveGridControl.View>
                    <live:ReceiptView/>
                </live:LiveGridControl.View>
                <live:LiveGridControl.ColumnDefinitions>
                    <UtilCore:ReceiptColumn ColumnName="DeductionTypeId" Caption="Kesinti Türü" EditorType="ComboBox" ComboLookup="PosDeductionTypeList" ComboDisplayMember="PosDeductionTypeName" ComboValueMember="RecId" Width="200"/>
                    <UtilCore:ReceiptColumn ColumnName="CardCategory" Caption="Kart Kategorisi" EditorType="ComboBox" ComboLookup="PosCardCategoryList" ComboDisplayMember="Display" ComboValueMember="Value" Width="180"/>
                    <UtilCore:ReceiptColumn ColumnName="InstallmentCount" Caption="Taksit Sayısı" Width="90" EditorType="TextEditor" UdtType="UdtInt16"/>
                    <UtilCore:ReceiptColumn ColumnName="RatePercent" Caption="Oran (%)" Width="100" UsageType="Amount" EditorType="MaskEditor" UdtType="UdtAmount"/>
                    <UtilCore:ReceiptColumn ColumnName="FixedAmount" Caption="Sabit Tutar" Width="110" UsageType="Amount" EditorType="MaskEditor" UdtType="UdtAmount"/>
                    <UtilCore:ReceiptColumn ColumnName="BlockDays" Caption="Bloke / Valör Günü" Width="120" EditorType="TextEditor" UdtType="UdtInt16"/>
                    <UtilCore:ReceiptColumn ColumnName="CalculationBase" Caption="Hesaplama Tabanı" EditorType="ComboBox" ComboLookup="PosCalculationBaseList" ComboDisplayMember="Display" ComboValueMember="Value" Width="120"/>
                    <UtilCore:ReceiptColumn ColumnName="ValidFrom" Caption="Geçerlilik Başlangıcı" Width="140" UsageType="Date" EditorType="DateEditor" UdtType="UdtDate" FormatString="dd.MM.yyyy" MaskString="dd.MM.yyyy"/>
                    <UtilCore:ReceiptColumn ColumnName="ValidTo" Caption="Geçerlilik Bitişi" Width="140" UsageType="Date" EditorType="DateEditor" UdtType="UdtDate" FormatString="dd.MM.yyyy" MaskString="dd.MM.yyyy"/>
                    <UtilCore:ReceiptColumn ColumnName="InUse" Caption="Aktif" Width="70" UsageType="None" EditorType="CheckBox" UdtType="UdtBool"/>
                </live:LiveGridControl.ColumnDefinitions>
            </live:LiveGridControl>
        </GroupBox>
    </Grid>
</UserControl>
