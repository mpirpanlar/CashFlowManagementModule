<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lange="clr-namespace:Sentez.Common.Localization;assembly=LiveCore.Desktop"
    xmlns:sye="clr-namespace:Sentez.Common.Extension;assembly=LiveCore.Desktop"
    xmlns:UtilCore="clr-namespace:Sentez.Common.Utilities;assembly=LiveCore"
    xmlns:live="clr-namespace:LiveCore.Desktop.UI.Controls;assembly=LiveCore.Desktop"
    x:Name="MetaFixedPaymentType"
    Tag="{lange:TranslateExtension Tekrar Eden Ödeme Tipleri}">
    <Grid Margin="5">
        <live:LiveGridControl x:Name="gridDetail"
                              MaxHeight="2000"
                              TableName="Meta_FixedPaymentType"
                              BusinessObject="{Binding ActiveBO}"
                              ItemsSource="{Binding ActiveBO.MasterTable}"
                              Lookups="{sye:SBinding Lists}">
            <live:LiveGridControl.ColumnDefinitions>
                <UtilCore:ReceiptColumn ColumnName="FixedPaymentTypeCode" Caption="Kod" EditorType="TextEditor" NewRowCheckColumn="True" Width="120"/>
                <UtilCore:ReceiptColumn ColumnName="FixedPaymentTypeName" Caption="Adı" EditorType="TextEditor" Width="350"/>
                <UtilCore:ReceiptColumn ColumnName="InUse" Caption="Kullanımda" EditorType="CheckBox" Width="80"/>
                <UtilCore:ReceiptColumn ColumnName="IsCollection" Caption="Tahsilat Tipi" EditorType="CheckBox" Width="90"/>
            </live:LiveGridControl.ColumnDefinitions>
            <live:LiveGridControl.View>
                <live:ReceiptView/>
            </live:LiveGridControl.View>
        </live:LiveGridControl>
    </Grid>
</UserControl>
