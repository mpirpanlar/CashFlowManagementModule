<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:lange="clr-namespace:Sentez.Common.Localization;assembly=LiveCore.Desktop"
    xmlns:UtilCore="clr-namespace:Sentez.Common.Utilities;assembly=LiveCore"
    xmlns:live="clr-namespace:LiveCore.Desktop.UI.Controls;assembly=LiveCore.Desktop"
    xmlns:sye="clr-namespace:Sentez.Common.Extension;assembly=LiveCore.Desktop"
    x:Name="CreditCardDetailAnalysisView"
    Tag="CreditCardDetailAnalysisViewW">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <live:LiveLabel VerticalContentAlignment="Center" Margin="0,0,8,0" Content="{lange:TranslateExtension Yıl}"/>
            <live:LiveCalculatorEdit Width="80" Margin="0,0,12,0" EditValue="{Binding SelectedYear}"/>
            <live:LiveButton MinWidth="100" Content="{lange:TranslateExtension Yenile}" Command="{Binding CmdList[RefreshCreditCardAnalysisCommand]}"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Margin="0,0,0,8" Text="{Binding SummaryText}" FontWeight="SemiBold"/>

        <GroupBox Grid.Row="2" Header="{lange:TranslateExtension KRD. KART DETAYI}">
            <live:LiveGridControl x:Name="gridCreditCardAnalysis"
                                  ShowBorder="False"
                                  AutoPopulateColumns="False"
                                  SelectionMode="Row"
                                  AllowNewRow="False"
                                  AllowDeleteRow="False"
                                  ItemsSource="{Binding AnalysisData}">
                <live:LiveGridControl.View>
                    <live:ListView/>
                </live:LiveGridControl.View>
            </live:LiveGridControl>
        </GroupBox>
    </Grid>
</UserControl>
