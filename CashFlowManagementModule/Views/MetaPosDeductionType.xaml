<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lange="clr-namespace:Sentez.Common.Localization;assembly=LiveCore.Desktop"
    xmlns:sye="clr-namespace:Sentez.Common.Extension;assembly=LiveCore.Desktop"
    xmlns:UtilCore="clr-namespace:Sentez.Common.Utilities;assembly=LiveCore"
    xmlns:live="clr-namespace:LiveCore.Desktop.UI.Controls;assembly=LiveCore.Desktop"
    x:Name="MetaPosDeductionType"
    Tag="{lange:TranslateExtension Pos Kesinti Türleri}">
    <Grid Margin="5">
        <live:LiveGridControl x:Name="gridDetail"
                              MaxHeight="2000"
                              TableName="Meta_PosDeductionType"
                              BusinessObject="{Binding ActiveBO}"
                              ItemsSource="{Binding ActiveBO.MasterTable}"
                              AllowNewRow="True"
                              AllowDeleteRow="True"
                              Lookups="{sye:SBinding Lists}">
            <live:LiveGridControl.ColumnDefinitions>
                <UtilCore:ReceiptColumn ColumnName="PosDeductionTypeCode" Caption="Kod" EditorType="TextEditor" NewRowCheckColumn="True" Width="120"/>
                <UtilCore:ReceiptColumn ColumnName="PosDeductionTypeName" Caption="Adı" EditorType="TextEditor" Width="350"/>
                <UtilCore:ReceiptColumn ColumnName="InUse" Caption="Kullanımda" EditorType="CheckBox" Width="80"/>
            </live:LiveGridControl.ColumnDefinitions>
            <live:LiveGridControl.View>
                <live:ReceiptView/>
            </live:LiveGridControl.View>
        </live:LiveGridControl>
    </Grid>
</UserControl>
