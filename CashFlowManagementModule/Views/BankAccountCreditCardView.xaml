<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:lange="clr-namespace:Sentez.Common.Localization;assembly=LiveCore.Desktop"
    xmlns:UtilCore="clr-namespace:Sentez.Common.Utilities;assembly=LiveCore"
    xmlns:live="clr-namespace:LiveCore.Desktop.UI.Controls;assembly=LiveCore.Desktop"
    xmlns:sye="clr-namespace:Sentez.Common.Extension;assembly=LiveCore.Desktop"
    x:Name="BankAccountCreditCardView"
    Tag="BankAccountCreditCardViewW">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="{lange:TranslateExtension Kart Bilgileri}" Margin="0,0,0,5">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <live:LiveLabel Grid.Column="0" HorizontalAlignment="Right" HorizontalContentAlignment="Right" Padding="2" VerticalContentAlignment="Center" Width="140" Content="{lange:TranslateExtension Son Kullanma Ay}"/>
                <live:LiveCalculatorEdit Grid.Column="1" Margin="2,1,1,0" HorizontalAlignment="Left" Width="100" EditValue="{sye:SBinding Field=Erp_BankAccount.UD_CreditCardExpiryMonth}"/>

                <live:LiveLabel Grid.Column="2" HorizontalAlignment="Right" HorizontalContentAlignment="Right" Padding="2" VerticalContentAlignment="Center" Width="140" Content="{lange:TranslateExtension Son Kullanma Yıl}"/>
                <live:LiveCalculatorEdit Grid.Column="3" Margin="2,1,1,0" HorizontalAlignment="Left" Width="100" EditValue="{sye:SBinding Field=Erp_BankAccount.UD_CreditCardExpiryYear}"/>

                <live:LiveLabel Grid.Column="4" HorizontalAlignment="Right" HorizontalContentAlignment="Right" Padding="2" VerticalContentAlignment="Center" Width="140" Content="{lange:TranslateExtension Hesap Kesim Tarihi}"/>
                <live:LiveDateEdit MaskType="DateTimeAdvancingCaret" Grid.Column="5" Margin="2,1,1,0" HorizontalAlignment="Left" Width="97" DateTime="{Binding Path=ActiveBO.CurrentRow.UD_StatementCutDate}" MaskUseAsDisplayFormat="True"/>

                <live:LiveLabel Grid.Column="6" HorizontalAlignment="Right" HorizontalContentAlignment="Right" Padding="2" VerticalContentAlignment="Center" Width="140" Content="{lange:TranslateExtension Son Ödeme Tarihi}"/>
                <live:LiveDateEdit MaskType="DateTimeAdvancingCaret" Grid.Column="7" Margin="2,1,1,0" HorizontalAlignment="Left" Width="97" DateTime="{Binding Path=ActiveBO.CurrentRow.UD_PaymentDueDate}" MaskUseAsDisplayFormat="True"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
            <live:LiveButton MinWidth="150" Margin="2" Content="{lange:TranslateExtension Dönemleri Oluştur}" Command="{Binding CmdList[GenerateCreditCardPeriodsCommand]}"/>
        </StackPanel>

        <GroupBox Grid.Row="2" Header="{lange:TranslateExtension Ekstre Dönemleri}">
            <live:LiveGridControl x:Name="gridCreditCardPeriods"
                                  ShowBorder="False"
                                  AutoPopulateColumns="False"
                                  SelectionMode="Row"
                                  AllowNewRow="False"
                                  AllowDeleteRow="False"
                                  ItemsSource="{sye:SBinding ActiveBO.Data.Tables[Erp_BankAccountCreditCardPeriod]}"
                                  TableName="Erp_BankAccountCreditCardPeriod">
                <live:LiveGridControl.View>
                    <live:ListView/>
                </live:LiveGridControl.View>
                <live:LiveGridControl.ColumnDefinitions>
                    <UtilCore:ReceiptColumn ColumnName="PeriodNo" Caption="Dönem No" Width="70" UsageType="None" DataType="{x:Type system:Int16}" EditorType="ReadOnlyTextEditor" UdtType="UdtInt16"/>
                    <UtilCore:ReceiptColumn ColumnName="PeriodYear" Caption="Yıl" Width="60" UsageType="None" DataType="{x:Type system:Int16}" EditorType="ReadOnlyTextEditor" UdtType="UdtInt16"/>
                    <UtilCore:ReceiptColumn ColumnName="PeriodMonth" Caption="Ay" Width="50" UsageType="None" DataType="{x:Type system:Int16}" EditorType="ReadOnlyTextEditor" UdtType="UdtInt16"/>
                    <UtilCore:ReceiptColumn ColumnName="StatementStartDate" Caption="Dönem Başlangıç" Width="110" UsageType="Date" DataType="{x:Type system:DateTime}" EditorType="ReadOnlyTextEditor" UdtType="UdtDate"/>
                    <UtilCore:ReceiptColumn ColumnName="StatementDate" Caption="Hesap Kesim" Width="110" UsageType="Date" DataType="{x:Type system:DateTime}" EditorType="ReadOnlyTextEditor" UdtType="UdtDate"/>
                    <UtilCore:ReceiptColumn ColumnName="PaymentDueDate" Caption="Son Ödeme" Width="110" UsageType="Date" DataType="{x:Type system:DateTime}" EditorType="ReadOnlyTextEditor" UdtType="UdtDate"/>
                    <UtilCore:ReceiptColumn ColumnName="CardExpiryDate" Caption="Kart Son Kullanma" Width="120" UsageType="Date" DataType="{x:Type system:DateTime}" EditorType="ReadOnlyTextEditor" UdtType="UdtDate"/>
                </live:LiveGridControl.ColumnDefinitions>
            </live:LiveGridControl>
        </GroupBox>
    </Grid>
</UserControl>
